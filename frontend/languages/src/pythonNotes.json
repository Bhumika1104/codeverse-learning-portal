      "heading": "2. Variable Rules"
    },
    {
      "type": "list",
      "items": [
        "Must start with letter or underscore (_)",
        "Cannot start with number",
        "Cannot use keywords (if, else, for)",
        "Case-sensitive (name ≠ Name)"
      ]
    },

    {
      "type": "code",
      "language": "python",
      "code": "name = \"Bhumika\"\n_age = 20\ntotalMarks = 95"
    },

    {
      "type": "heading",
      "heading": "3. Internal Working"
    },
    {
      "type": "text",
