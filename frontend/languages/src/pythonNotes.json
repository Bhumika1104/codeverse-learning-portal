    {
      "type": "heading",
      "heading": "6. Difference (Important)"
    },
    {
      "type": "list",
      "items": [
        "List → Mutable, ordered, duplicates allowed",
        "Tuple → Immutable, ordered",
        "Set → Unordered, unique elements"
      ]
    },

    {
      "type": "heading",
      "heading": "7. Key Points"
    },
    {
      "type": "list",
      "items": [
